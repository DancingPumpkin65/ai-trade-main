# Application
ENV=dev
SECRET_KEY=change-me

# Local data paths
DB_PATH=./data/trading.db
CHROMA_PERSIST_DIR=./data/chroma
LANGGRAPH_CHECKPOINT_PATH=./data/langgraph-checkpoints.sqlite

# Drahmi
DRAHMI_API_KEY=
DRAHMI_BASE_URL=https://api.drahmi.app/api
DRAHMI_DAILY_LIMIT=500

# MarketAux
MARKETAUX_API_KEY=
MARKETAUX_BASE_URL=https://api.marketaux.com/v1

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=morocco-trading-agents

# Alpaca
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_ENABLED=true
ALPACA_SUBMIT_ORDERS=false
